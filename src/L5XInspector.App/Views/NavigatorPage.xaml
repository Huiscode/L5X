<Page
    x:Class="L5XInspector.App.Views.NavigatorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="24" RowDefinitions="Auto,*,*" ColumnDefinitions="2*,3*" ColumnSpacing="16" RowSpacing="16">
        <StackPanel Grid.ColumnSpan="2" Spacing="4">
            <TextBlock Text="Program Navigator" FontSize="24" FontWeight="SemiBold" />
            <TextBlock x:Name="L5xFileText" Text="Loaded file: (none)" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>
        <Border Grid.Row="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="12">
            <StackPanel Spacing="8">
                <TextBlock Text="Task / Program Tree" FontWeight="SemiBold" />
                <TextBlock Text="Tasks → Programs → Routines → AOIs" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Border>
        <Border Grid.Row="1" Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="12">
            <StackPanel Spacing="8">
                <TextBlock Text="Dependency Map" FontWeight="SemiBold" />
                <TextBlock Text="Interactive graph canvas" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Border>
        <Border Grid.Row="2" Grid.ColumnSpan="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="12">
            <StackPanel Spacing="8">
                <TextBlock Text="Inspector" FontWeight="SemiBold" />
                <TextBlock Text="Selected item details, read/write tags, call chain" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
