<Page
    x:Class="L5XInspector.App.Views.ImpactPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="24" RowDefinitions="Auto,*" RowSpacing="16">
        <TextBlock Text="Change Impact Lens" FontSize="24" FontWeight="SemiBold" />
        <Grid Grid.Row="1" ColumnDefinitions="2*,3*" ColumnSpacing="16">
            <StackPanel Spacing="16">
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Impact Summary" FontWeight="SemiBold" />
                        <TextBlock Text="Tags, stations, AOIs affected" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Border>
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Metrics" FontWeight="SemiBold" />
                        <TextBlock Text="Depth, breadth, and affected stations" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Border>
            </StackPanel>
            <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="12">
                <StackPanel Spacing="8">
                    <TextBlock Text="Downstream Paths" FontWeight="SemiBold" />
                    <TextBlock Text="Graph of potential downstream effects" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>

