<Window
    x:Class="L5XInspector.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:L5XInspector.App"
    mc:Ignorable="d"
    Title="L5X Inspector">

    <Grid>
        <NavigationView x:ConnectionId='2' x:Name="RootNav"
                        IsSettingsVisible="True"
                        PaneDisplayMode="Left"
                                                             >
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Navigator" Tag="Navigator">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Map" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Stations" Tag="Stations">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="MapDrive" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Trace" Tag="Trace">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Find" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="AOI / UDT" Tag="AoiUdt">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Library" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Impact" Tag="Impact">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Important" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Learning" Tag="Learning">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Play" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
            <NavigationView.Header>
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button x:ConnectionId='3' Content="Import L5X"                       />
                    <Button x:ConnectionId='4' Content="Station Rules"                             />
                    <AutoSuggestBox Width="320" PlaceholderText="Search tags, routines, AOIs" />
                    <TextBlock x:ConnectionId='5' x:Name="HeaderFileText" Text="Loaded: (none)"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </NavigationView.Header>
            <Frame x:ConnectionId='6' x:Name="ContentFrame" />
        </NavigationView>
    </Grid>
</Window>

